<!DOCTYPE html>
<html lang="fr">

<head>
  <meta charset="UTF-8">
  <meta http-equiv="X-UA-Compatible" content="IE=edge">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Laptops - NexusChop</title>

  <!--
    - favicon
  -->
  <link rel="shortcut icon" href="./assets/images/logo/favicon.ico" type="image/x-icon">

  <!--
    - custom css link
  -->
  <link rel="stylesheet" href="./assets/css/style-prefix.css">
  <link rel="stylesheet" href="./assets/css/menu-content-styles.css">
  <link rel="stylesheet" href="./assets/css/high-tech-mega-menu.css">
  <link rel="stylesheet" href="./assets/css/fixed-menu.css">
  
  <!--
    - logo styling
  -->
  <style>
    .header-logo {
      font-size: 24px !important;
      font-weight: bold !important;
      color: #333 !important;
    }
    
    .orange-letter {
      color: #ff6600 !important;
    }
    
    /* Carousel styling */
    .banner-btn {
      background: #ff6600 !important;
      color: white !important;
      border: none !important;
      padding: 12px 24px !important;
      border-radius: 5px !important;
      font-weight: bold !important;
      text-decoration: none !important;
      display: inline-block !important;
      transition: all 0.3s ease !important;
    }
    
    .banner-btn:hover {
      background: #ff5200 !important;
      color: white !important;
    }
    
    /* Hover effects in orange */
    .menu-title:hover {
      color: #ff6600 !important;
    }
    
    .banner-subtitle:hover {
      color: #ff6600 !important;
      transform: scale(1.05) !important;
      transition: all 0.3s ease !important;
    }
    
    .banner-title:hover {
      color: #ff8800 !important;
      transform: scale(1.05) !important;
      transition: all 0.3s ease !important;
    }
    
    .orange-letter:hover {
      color: #ff8800 !important;
    }
    
    /* Page header styling */
    .page-header {
      background: linear-gradient(135deg, #a8edea 0%, #fed6e3 100%);
      color: white;
      padding: 60px 0;
      text-align: center;
    }
    
    .page-title {
      font-size: 48px;
      font-weight: 700;
      margin-bottom: 10px;
      text-shadow: 2px 2px 4px rgba(0,0,0,0.3);
    }
    
    .page-subtitle {
      font-size: 18px;
      opacity: 0.9;
    }

    /* Social media icon colors */
    .social-link ion-icon[name="logo-facebook"] {
      color: #1877f2 !important;
    }
    
    .social-link ion-icon[name="logo-twitter"] {
      color: #1da1f2 !important;
    }
    
    .social-link ion-icon[name="logo-instagram"] {
      background: linear-gradient(45deg, #f09433 0%, #e6683c 25%, #dc2743 50%, #cc2366 75%, #bc1888 100%);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
    }
    
    .social-link ion-icon[name="logo-linkedin"] {
      color: #0077b5 !important;
    }
    
    /* Social media hover effects */
    .social-link:hover ion-icon[name="logo-facebook"] {
      color: #1464d2 !important;
      transform: scale(1.1);
    }
    
    .social-link:hover ion-icon[name="logo-twitter"] {
      color: #0c87c8 !important;
      transform: scale(1.1);
    }
    
    .social-link:hover ion-icon[name="logo-instagram"] {
      filter: brightness(1.2);
      transform: scale(1.1);
    }
    
    .social-link:hover ion-icon[name="logo-linkedin"] {
      color: #005a8f !important;
      transform: scale(1.1);
    }

    /* Static delivery message styling */
    .header-alert-news {
      overflow: visible !important;
      white-space: normal !important;
    }
    
    .header-alert-news p {
      margin: 0 !important;
    }
  </style>

  <!--
    - google font link
  -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700;800;900&display=swap"
    rel="stylesheet">

</head>

<body>

  <div class="overlay" data-overlay></div>

  <!--
    - HEADER
  -->

  <header>

    <div class="header-top">

      <div class="container">

        <ul class="header-social-container">

          <li>
            <a href="#" class="social-link">
              <ion-icon name="logo-facebook"></ion-icon>
            </a>
          </li>

          <li>
            <a href="#" class="social-link">
              <ion-icon name="logo-twitter"></ion-icon>
            </a>
          </li>

          <li>
            <a href="#" class="social-link">
              <ion-icon name="logo-instagram"></ion-icon>
            </a>
          </li>

          <li>
            <a href="#" class="social-link">
              <ion-icon name="logo-linkedin"></ion-icon>
            </a>
          </li>

        </ul>

        <div class="header-alert-news">
          <p style="color: #333; font-weight: normal;">
            <b>Livraison gratuite Cette semaine pour toute commande supérieure à</b> <span style="color: #ff6600; font-weight: bold;">1000 XAF</span>
          </p>
        </div>

        <div class="header-top-actions">

          <select name="currency">

            <option value="xaf" selected>XAF</option>
            <option value="usd">USD &dollar;</option>
            <option value="eur">EUR &euro;</option>

          </select>

          <select name="language">

            <option value="fr" selected>Fran&ccedil;ais</option>
            <option value="en-US">English</option>

          </select>

        </div>

      </div>

    </div>

    <div class="header-main">

      <div class="container">

        <a href="#" class="header-logo">
          <span class="orange-letter">N</span>exus<span class="orange-letter">C</span>hop
        </a>

        <div class="header-search-container">

          <input type="search" name="search" class="search-field" placeholder="Recherchez un laptop...">

          <button class="search-btn">
            <ion-icon name="search-outline"></ion-icon>
          </button>

        </div>

        <div class="header-user-actions">

          <button class="action-btn">
            <ion-icon name="person-outline"></ion-icon>
          </button>

          <button class="action-btn">
            <ion-icon name="heart-outline"></ion-icon>
            <span class="count">0</span>
          </button>

          <button class="action-btn" onclick="window.location.href='panier.html'">
            <ion-icon name="bag-handle-outline"></ion-icon>
            <span class="count cart-count">0</span>
          </button>

        </div>

      </div>

    </div>

    <nav class="desktop-navigation-menu">

      <div class="container">

        <ul class="desktop-menu-category-list">

